---
import type { CollectionEntry } from 'astro:content';
import ArticleMeta from '../components/blog/ArticleMeta.astro';
import ArticleNavigation from '../components/blog/ArticleNavigation.astro';
import TagList from '../components/common/TagList.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  article: CollectionEntry<'blog'>;
  previous?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { article, previous, next } = Astro.props;
const title = `${article.data.title} — Galilieo`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.publishedAt,
  dateModified: article.data.updatedAt ?? article.data.publishedAt,
  author: { '@type': 'Person', name: 'Galilieo' },
  inLanguage: 'zh-CN',
  mainEntityOfPage: new URL(`/notes/${article.id}/`, 'https://galilieo.heart-island.cn').toString(),
};
---

<BaseLayout
  title={title}
  description={article.data.description}
  canonicalPath={`/notes/${article.id}/`}
  type="article"
  publishedTime={article.data.publishedAt}
  modifiedTime={article.data.updatedAt}
  jsonLd={jsonLd}
>
  <a class="skip-link" href="#main-content">跳到主要内容</a>
  <SiteHeader />
  <main class="page-main" id="main-content">
    <article class="article-page">
      <header class="page-header reveal">
        <p class="section-kicker">Notes / {article.data.category}</p>
        <h1>{article.data.title}</h1>
        <p>{article.data.description}</p>
        <ArticleMeta
          category={article.data.category}
          publishedAt={article.data.publishedAt}
          updatedAt={article.data.updatedAt}
          readingTime={article.data.readingTime}
        />
        <TagList items={article.data.tags} label="文章标签" />
      </header>
      <div class="prose reveal"><slot /></div>
      <p class="back-link"><a href="/notes/">← 返回博客列表</a></p>
      <ArticleNavigation previous={previous} next={next} />
    </article>
  </main>
  <SiteFooter />
</BaseLayout>
