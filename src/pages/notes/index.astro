---
import { getCollection } from 'astro:content';
import BlogDirectory from '../../components/blog/BlogDirectory.astro';
import SectionHeading from '../../components/common/SectionHeading.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('blog'))
  .filter((article) => !article.data.draft)
  .sort((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''));
---

<BaseLayout
  title="博客 — Galilieo"
  description="记录项目开发、问题复盘、学习过程和生活片段。"
  canonicalPath="/blog/"
>
  <a class="skip-link" href="#main-content">跳到主要内容</a>
  <SiteHeader />
  <main class="page-main interior-page interior-page--blog" id="main-content">
    <SectionHeading
      eyebrow="Notes"
      title="关于开发，也关于生活。"
      description="记录项目里的判断和复盘，也留下一些日常片段和阶段性的想法。"
    />
    {
      articles.length > 0 ? (
        <BlogDirectory articles={articles} />
      ) : (
        <div class="empty-state reveal">第一批文章正在整理中。</div>
      )
    }
  </main>
  <SiteFooter />
</BaseLayout>
