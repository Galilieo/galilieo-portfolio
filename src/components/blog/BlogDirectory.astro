---
import type { CollectionEntry } from 'astro:content';
import { createBlogCoverMap } from '../../lib/blog-cover';
import {
  createBlogCategoryGroups,
  getBlogTagSummaries,
  sortBlogArticles,
} from '../../lib/blog-directory';
import ArticleCard from './ArticleCard.astro';
import BlogDirectoryNavigation from './BlogDirectoryNavigation.astro';

interface Props {
  articles: CollectionEntry<'blog'>[];
}

const { articles } = Astro.props;
const groups = createBlogCategoryGroups(articles);
const categories = groups.map(({ name, id, count }) => ({ name, id, count }));
const tags = getBlogTagSummaries(articles);
const sortedForTags = sortBlogArticles(articles);
const coverMap = createBlogCoverMap(articles);
---

<section
  class:list={['blog-directory-layout', { 'has-single-category': groups.length === 1 }]}
  data-blog-directory
  aria-label="博客文章目录"
>
  {
    groups.length > 0 && (
      <aside class="blog-directory-layout__sidebar">
        <BlogDirectoryNavigation categories={categories} tags={tags} totalCount={articles.length} />
      </aside>
    )
  }

  <div class="blog-category-groups" data-blog-category-groups>
    {
      groups.map((group) => (
        <section
          class="blog-category-section"
          id={group.id}
          data-blog-category-section
          data-category-count={group.count}
        >
          <header class="blog-category-section__heading">
            <div>
              <p>Category</p>
              <h2>{group.name}</h2>
            </div>
            <span data-blog-category-visible-count>
              {String(group.count).padStart(2, '0')} articles
            </span>
          </header>
          <div class="article-grid">
            {group.articles.map((article) => (
              <ArticleCard article={article} artwork={coverMap.get(article.id)} headingLevel={3} />
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <section
    class="blog-category-section blog-tag-results"
    data-blog-tag-results
    aria-labelledby="blog-tag-results-title"
    hidden
  >
    <header
      class="blog-category-section__heading blog-tag-results__heading"
      data-blog-tag-results-heading
    >
      <div>
        <p>TAG INDEX</p>
        <h2 id="blog-tag-results-title">全部文章</h2>
      </div>
      <span data-blog-tag-results-count>
        {String(articles.length).padStart(2, '0')} articles
      </span>
    </header>
    <div class="article-grid" data-blog-tag-results-grid>
      {
        sortedForTags.map((article) => (
          <ArticleCard article={article} artwork={coverMap.get(article.id)} headingLevel={3} />
        ))
      }
    </div>
  </section>
</section>
