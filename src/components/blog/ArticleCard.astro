---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import alleyCover from '../../assets/images/covers/scene-alley.webp';
import bloomCover from '../../assets/images/covers/scene-bloom.webp';
import orbitCover from '../../assets/images/covers/scene-orbit.webp';
import TagList from '../common/TagList.astro';

interface Props {
  article: CollectionEntry<'blog'>;
  headingLevel?: 2 | 3;
  artworkIndex?: number;
}

const { article, headingLevel = 2, artworkIndex = 0 } = Astro.props;
const Heading = headingLevel === 3 ? 'h3' : 'h2';
const artworkSequences = {
  前端与移动端: [
    { image: alleyCover, key: 'alley' },
    { image: orbitCover, key: 'orbit' },
    { image: bloomCover, key: 'bloom' },
  ],
  实习复盘: [
    { image: alleyCover, key: 'alley' },
    { image: bloomCover, key: 'bloom' },
    { image: orbitCover, key: 'orbit' },
  ],
  工程笔记: [
    { image: orbitCover, key: 'orbit' },
    { image: bloomCover, key: 'bloom' },
    { image: alleyCover, key: 'alley' },
  ],
  'AI 应用学习': [
    { image: orbitCover, key: 'orbit' },
    { image: alleyCover, key: 'alley' },
    { image: bloomCover, key: 'bloom' },
  ],
  项目日志: [
    { image: bloomCover, key: 'bloom' },
    { image: alleyCover, key: 'alley' },
    { image: orbitCover, key: 'orbit' },
  ],
} as const;
const categorySequence =
  artworkSequences[article.data.category as keyof typeof artworkSequences] ??
  artworkSequences['项目日志'];
const artwork = article.data.cover
  ? { image: article.data.cover, key: 'custom' }
  : categorySequence[artworkIndex % categorySequence.length];
---

<article
  class="article-matrix-card reveal"
  data-article-card
  data-blog-entry
  data-article-tags={JSON.stringify(article.data.tags)}
>
  <a class="article-matrix-card__link" href={`/notes/${article.id}/`}>
    <div class="article-matrix-card__visual" aria-hidden="true">
      {
        (
          <Image
            class:list={[
              'article-matrix-card__cover',
              `article-matrix-card__cover--${artwork.key}`,
            ]}
            src={artwork.image}
            alt=""
            widths={[320, 480, 720]}
            sizes="(max-width: 760px) calc(100vw - 32px), (max-width: 1180px) 46vw, 430px"
            loading="lazy"
          />
        )
      }
      <span class="article-matrix-card__category">{article.data.category}</span>
    </div>
    <div class="article-matrix-card__body">
      <div class="article-matrix-card__topline">
        <span>{article.data.category}</span>
        <time datetime={article.data.publishedAt ?? undefined}>
          {article.data.publishedAt ?? article.data.homepageState}
        </time>
      </div>
      <Heading class="article-matrix-card__title">{article.data.title}</Heading>
      <p class="article-matrix-card__description">{article.data.description}</p>
      <TagList items={article.data.tags} label={`${article.data.title}文章标签`} />
      <footer class="article-matrix-card__footer">
        <span>{article.data.readingTime ? `${article.data.readingTime} min` : 'Note'}</span>
        <span class="article-matrix-card__arrow" aria-hidden="true">→</span>
      </footer>
    </div>
  </a>
</article>
