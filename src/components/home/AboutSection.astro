---
// 用途：关于页个人档案与真实介绍；成长时间线统一由归档页维护。
import { Image } from 'astro:assets';
import avatar from '../../assets/images/profile/galilieo-avatar.webp';
import { siteConfig } from '../../config/site';
---

<section class="about-dossier" aria-labelledby="about-title">
  <header class="about-dossier__identity reveal">
    <div class="about-dossier__identity-content">
      <Image
        class="about-dossier__avatar"
        src={avatar}
        alt={`${siteConfig.author.name} 的头像`}
        width={512}
        height={512}
        loading="eager"
      />
      <div>
        <p class="about-dossier__eyebrow">Identity / About</p>
        <h1 id="about-title">{siteConfig.author.name}</h1>
        <p class="about-dossier__role">{siteConfig.author.role}</p>
        <nav class="about-dossier__identity-links" aria-label="个人经历入口">
          <a href="/archive/?view=personal#personal-timeline">查看个人轨迹 →</a>
          <a href="/campus/">在校经历 →</a>
        </nav>
      </div>
    </div>
  </header>

  <div class="about-dossier__grid">
    <article class="about-dossier__story reveal">
      <p class="about-dossier__section-label">Narrative / 01</p>
      <h2>一边学习，一边把东西做出来。</h2>
      <p>
        我是
        Galilieo，目前就读于软件工程专业。相比只学习某一种框架，我更希望理解一个产品从页面、接口和数据，到
        AI 能力接入与最终交付的完整过程。
      </p>
      <p>
        目前的实习让我接触到真实 AI 聊天产品的前端与移动端开发。我会参与问题排查、交互修复、Android
        与 iOS 差异处理、自测和代码协作。这些经历也让我开始真正理解，项目开发并不只是把代码写出来。
      </p>
      <p>
        在实习之外，我持续开发个人项目「心屿」。它最初是一个 Spring Boot 与 Vue 3
        项目，现在正在逐步加入多轮对话、记忆、情绪报告、RAG 和工具调用能力。
      </p>
      <p>
        我的目标不是把自己限制在普通前端或普通 Java CRUD 开发，而是逐步走向 AI 应用开发、Agent 和 AI
        全栈方向。
      </p>
    </article>

    <aside class="about-dossier__facts reveal" aria-label="个人信息摘要">
      <p class="about-dossier__section-label">Facts / 02</p>
      <dl>
        <div>
          <dt>当前身份</dt>
          <dd>软件工程专业学生 / 开发实习生</dd>
        </div>
        <div>
          <dt>主要方向</dt>
          <dd>AI 应用开发 / Agent / RAG / AI 全栈</dd>
        </div>
        <div>
          <dt>当前项目</dt>
          <dd>heart-island 心屿</dd>
        </div>
        <div>
          <dt>近期关注</dt>
          <dd>多轮对话、长期记忆、SSE、RAG、Tool Calling</dd>
        </div>
      </dl>
    </aside>
  </div>

  <footer class="about-dossier__contact reveal">
    <div>
      <p class="about-dossier__section-label">Contact / 03</p>
      <h2>继续看看，或者和我聊聊。</h2>
    </div>
    <div class="about-dossier__links">
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      <a href={`mailto:${siteConfig.email}`}>Email</a>
      <a href={siteConfig.heartIsland} target="_blank" rel="noopener noreferrer">心屿 ↗</a>
    </div>
  </footer>
</section>
