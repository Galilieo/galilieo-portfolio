---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { createBlogCoverMap, getBlogCover } from '../../lib/blog-cover';

const publishedPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.publishedAt)
  .sort((a, b) => String(b.data.publishedAt).localeCompare(String(a.data.publishedAt)));
const selectedPosts = [
  ...publishedPosts.filter((post) => post.data.featured),
  ...publishedPosts.filter((post) => !post.data.featured),
].slice(0, 3);
const coverMap = createBlogCoverMap(publishedPosts);
const selectedSlides = selectedPosts.map((post) => ({
  post,
  artwork: coverMap.get(post.id) ?? getBlogCover(post),
}));
---

<section
  class="dashboard-card home-carousel home-notes reveal"
  id="blog"
  aria-labelledby="latest-posts-title"
  aria-roledescription="carousel"
  data-home-carousel
  data-home-autoplay="7600"
  style="--delay: 240ms"
>
  <a class="home-carousel__section-link" href="/blog/" aria-label="查看全部文章"></a>
  <header class="home-carousel__header">
    <div>
      <p>Selected writing</p>
      <h2 id="latest-posts-title">精选文章</h2>
    </div>
  </header>

  {
    selectedSlides.length > 0 ? (
      <div class="home-carousel__viewport">
        {selectedSlides.map(({ post, artwork }, index) => (
          <article
            class="home-carousel__slide"
            data-home-slide
            hidden={index !== 0}
            role="group"
            aria-roledescription="slide"
            aria-label={`${index + 1} / ${selectedSlides.length}`}
          >
            <a class="home-carousel__card-link" href={`/notes/${post.id}/`}>
              <div
                class:list={[
                  'home-carousel__media',
                  'home-notes__media',
                  `home-carousel__media--tone-${(index + 1) % 3}`,
                ]}
                data-blog-cover={`${post.id}:${artwork.key}`}
              >
                <Image
                  class="home-carousel__cover"
                  src={artwork.image}
                  alt=""
                  widths={[360, 520, 720]}
                  sizes="(max-width: 999px) 100vw, 36vw"
                  loading={index === 0 ? 'eager' : 'lazy'}
                  style={`object-position: ${artwork.position}`}
                />
              </div>
              <div class="home-carousel__scrim" aria-hidden="true" />
              <div class="home-carousel__content home-notes__content">
                <div class="home-carousel__eyebrow">
                  <span>{post.data.category}</span>
                  {post.data.publishedAt && (
                    <time datetime={post.data.publishedAt}>{post.data.publishedAt}</time>
                  )}
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <ul aria-label="文章标签">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="home-carousel__empty">第一批文章正在整理中。</p>
    )
  }

  {
    selectedSlides.length > 1 && (
      <div class="home-carousel__dots" aria-label="选择文章">
        {selectedSlides.map(({ post }, index) => (
          <button
            type="button"
            data-home-dot
            data-home-index={index}
            aria-label={`显示文章：${post.data.title}`}
            aria-current={index === 0 ? 'true' : 'false'}
          >
            <span />
          </button>
        ))}
      </div>
    )
  }
</section>
