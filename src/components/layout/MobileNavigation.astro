---
import { siteConfig } from '../../config/site';

// 用途：输出桌面与移动端共用的主导航；数据来源：src/config/site.ts；后续统一修改配置。
const currentPath = Astro.url.pathname;
---

<nav class="site-nav" id="site-navigation" aria-label="主导航">
  {
    siteConfig.navigation.map((item) => {
      const itemPath = new URL(item.href, siteConfig.url).pathname;
      const isActive =
        item.href === '/'
          ? currentPath === '/'
          : !item.href.includes('#') && itemPath === currentPath;
      return (
        <a class:list={{ 'is-active': isActive }} href={item.href}>
          {item.label}
        </a>
      );
    })
  }
</nav>
