server {
    listen 80;
    listen [::]:80;
    server_name galilieo.heart-island.cn;

    root /var/www/galilieo-portfolio;
    index index.html;
    charset utf-8;

    include /etc/nginx/mime.types;
    types {
        image/avif avif;
        image/svg+xml svg svgz;
        image/webp webp;
        video/mp4 mp4;
        video/webm webm;
    }

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/manifest+json
        application/rss+xml
        application/xml
        image/svg+xml;

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    location / {
        # Astro 为静态多页面网站：查找实际文件或目录，不回退到首页。
        try_files $uri $uri/ =404;
    }

    location ~* \.(?:css|js|mjs|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf)$ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header X-Content-Type-Options "nosniff" always;
    }

    location ~* \.(?:mp4|webm)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        add_header X-Content-Type-Options "nosniff" always;
    }

    error_page 404 /404.html;
    location = /404.html {
        internal;
    }
}
